            Value: true
          wrist_bevel:
            Alpha: 1
            Show Axes: false
            Show Trail: false
            Value: true
          wrist_carrier:
            Alpha: 1
            Show Axes: false
            Show Trail: false
            Value: true
        Robot Alpha: 0.5
        Show Robot Collision: false
        Show Robot Visual: true
        Use Fixed Robot Color: false
        Value: ""
      Robot Description: robot_description
      Scene:
        Attached Body Color: 150; 50; 150
        Scene Alpha: 0.8999999761581421
        Scene Color: 50; 230; 50
        Value: true
        Voxel Coloring: Z-Axis
        Voxel Rendering: Occupied Voxels
      Show Trail: false
      State Display Time: 0.05 s
      Task Solution Topic: /solution
      Tasks:
        demo task: 0
      Trail Step Size: 1
      Value: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: false
        bottom_base:
          Value: false
        claw_base:
          Value: true
        elbow:
          Value: false
        forearm:
          Value: false
        left_claw:
          Value: false
        right_claw:
          Value: false
        shoulder:
          Value: false
        top_base:
          Value: false
        world:
          Value: false
        wrist_bevel:
          Value: true
        wrist_carrier:
          Value: false
      Marker Scale: 1
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Tree:
        world:
          bottom_base:
            top_base:
              shoulder:
                elbow:
                  forearm:
                    wrist_carrier:
                      wrist_bevel:
                        claw_base:
                          left_claw:
                            {}
                          right_claw:
                            {}
      Update Interval: 0
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: world
    Frame Rate: 30
  Name: root
  Tools:
